# ===========================================
# Rozetta PMS — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.

# --- Database ---
POSTGRES_USER=rozetta
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=rozetta_pms
DATABASE_URL=postgresql://rozetta:change_me_to_a_strong_password@db:5432/rozetta_pms

# --- Backend ---
# e.g. `openssl rand -hex 32`
SECRET_KEY=change_me_to_a_random_string
# same-origin in prod; set to your domain
BACKEND_CORS_ORIGINS=http://localhost:5173
# Public origin of the app. In production these are your HTTPS domain.
# Local dev defaults (used if unset): http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Emails granted ADMIN automatically on first Microsoft sign-in (comma-separated).
ADMIN_EMAILS=

# Dev-only test login (the "Dev Login (Admin)" button). MUST be false in production.
ENABLE_DEV_LOGIN=false

# --- Reverse proxy (Caddy, production only) ---
# The bare domain Caddy serves and provisions a TLS cert for, e.g. pms.rozettainstitute.com
# Use ":80" for a quick local/no-domain smoke test (skips HTTPS).
SITE_ADDRESS=pms.rozettainstitute.com

# --- Microsoft Azure AD OAuth ---
# Get these from Azure Portal > App registrations
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
# Must EXACTLY match the redirect URI registered in Azure.
# Production: https://<your-domain>/api/auth/callback
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# --- Claude API (optional — enables AI Notetaker) ---
# ANTHROPIC_API_KEY=your-claude-api-key
